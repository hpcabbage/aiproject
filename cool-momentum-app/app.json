{
  "expo": {
    "name": "Momentum",
    "slug": "cool-momentum-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#070B17"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.hpcabbage.momentum",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#070B17"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-notifications",
        {
          "color": "#7C5CFF",
          "defaultChannel": "momentum-reminders"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f5b9b031-e13c-4a65-abab-3eb4c66d3ad6"
      }
    }
  }
}
